Project sistem_inventaris_barang {
  database_type: "PostgreSQL"
}

Table users {
  id integer [pk, increment]
  nama varchar
  email varchar [unique]
  password varchar
}

Table categories {
  id integer [pk, increment]
  category_name varchar
  description text
}

Table items {
  id integer [pk, increment]
  item_code varchar [unique]
  item_name varchar
  stock integer
  item_condition varchar
  location varchar
  entry_date date
  category_id integer [ref: > categories.id]
}

Table transactions {
  id integer [pk, increment]
  item_id integer [ref: > items.id]
  user_id integer [ref: > users.id]
  transaction_type varchar
  quantity integer
  transaction_date date
  description text
}
